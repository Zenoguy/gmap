{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite":   true,
    "target":      "ES2020",
    "lib":         ["ES2020", "DOM", "DOM.Iterable"],
    "module":      "ESNext",
    "moduleResolution": "Bundler",
    "jsx":         "react-jsx",
    "outDir":      "./dist",
    "rootDir":     "./src"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
