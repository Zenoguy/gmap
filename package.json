{
  "name": "gmap-workspace",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build":     "turbo run build",
    "test":      "turbo run test",
    "lint":      "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean":     "turbo run clean",
    "dev:cli":   "pnpm --filter @gmap/cli dev",
    "dev:dash":  "pnpm --filter @gmap/dashboard dev"
  },
  "devDependencies": {
    "turbo":                 "2.3.3",
    "typescript":            "5.5.4",
    "eslint":                "9.9.1",
    "@typescript-eslint/eslint-plugin": "8.4.0",
    "@typescript-eslint/parser":        "8.4.0",
    "vitest":                "2.1.1",
    "@vitest/coverage-v8":   "2.1.1",
    "prettier":              "3.3.3"
  },
  "packageManager": "pnpm@9.9.0"
}
